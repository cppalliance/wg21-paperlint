# Paperlint API keys
# Copy this file to .env and fill in your keys

# Required for Discovery (Anthropic Citations API)
ANTHROPIC_API_KEY=sk-ant-...

# Required for Gate, Extractor, Metadata (OpenRouter)
OPENROUTER_API_KEY=sk-or-...

# Optional: custom OpenRouter-compatible base URL (default: https://openrouter.ai/api/v1)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
